PORT=3001
ADMIN_KEY=daogreen-admin-change-me
DATABASE_PATH=./data/daogreen.db
CORS_ORIGIN=http://localhost:5173

# VPS за nginx (/spec/):
# VITE_BASE_PATH=/spec/
# VITE_PUBLIC_URL=http://YOUR_HOST/spec

# PostgreSQL (этап 2, см. backend/docs/DATABASE.md):
# DATABASE_DRIVER=postgres
# DATABASE_URL=postgresql://user:pass@localhost:5432/daogreen

# S3 / Object Storage (этап 2):
# STORAGE_DRIVER=s3
# S3_BUCKET=daogreen-uploads
# S3_REGION=ru-central1
# S3_ENDPOINT=https://storage.yandexcloud.net
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_PUBLIC_URL=https://cdn.example.com

# Supabase backup (опционально):
# SUPABASE_URL=
# SUPABASE_SERVICE_KEY=
