# Frontend (Vite). Copy to .env.local for local dev.
# VITE_API_URL=http://localhost:3001
# VITE_BASE_PATH=/
# VITE_PUBLIC_URL=http://localhost:5173
# VITE_CALC_ORIGIN=

# Production build (VPS/nginx at /spec/):
# VITE_BASE_PATH=/spec/
# VITE_PUBLIC_URL=http://YOUR_HOST/spec

# VPS deploy scripts (scripts/vps-*.mjs) — do not commit real values
# VPS_HOST=
# VPS_USER=root
# VPS_PASSWORD=
# VPS_APP_ROOT=/opt/daogreen-spec

# Backend API — see backend/.env.example
